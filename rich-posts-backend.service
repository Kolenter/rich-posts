[Unit]
Description=Rich Posts API — FastAPI
After=network.target

[Service]
Type=simple
# Замените /opt/rich-posts на путь установки на вашем сервере
WorkingDirectory=/opt/rich-posts/backend
EnvironmentFile=/opt/rich-posts/backend/.env
ExecStart=/opt/rich-posts/backend/venv/bin/python run.py
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
