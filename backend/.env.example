# Токен вашего бота (BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram user id админов (опционально, зарезервировано для будущих функций)
# ADMIN_IDS=123456789

# Канал по умолчанию для публикации (@channel или -100...)
RICH_POSTS_DEFAULT_CHANNEL=

# URL mini app для кнопки меню бота
MINIAPP_URL=https://your.domain/

# Webhook Telegram (для /start и кнопки «Открыть редактор»)
WEBHOOK_URL=https://your.domain/api/v1/telegram/webhook
# ОБЯЗАТЕЛЬНО. Сгенерируйте: python3 -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET=

# Порт локального API
RICH_POSTS_PORT=8035

# Публичный URL загруженных медиа (должен совпадать с nginx /uploads/)
RICH_POSTS_UPLOAD_PUBLIC_BASE=https://your.domain/uploads

# ffmpeg для конвертации голосовых (опционально, иначе ищется в PATH)
# FFMPEG_PATH=/usr/bin/ffmpeg

# Безопасность (см. SECURITY.md)
ALLOWED_ORIGINS=https://your.domain
TRUSTED_HOSTS=your.domain,127.0.0.1,localhost
INIT_DATA_MAX_AGE_SEC=86400
INIT_DATA_MAX_LEN=8192
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=20
DRAFT_RATE_LIMIT_PER_MINUTE=12
DRAFT_RATE_BURST=6
UPLOAD_RATE_LIMIT_PER_MINUTE=20
UPLOAD_RATE_BURST=8
PUBLISH_RATE_LIMIT_PER_MINUTE=8
PUBLISH_RATE_BURST=4
RICH_POSTS_ENABLE_DOCS=0

# Опционально: ограничить publish только этими каналами (пусто = любой канал, где user admin)
# PUBLISH_ALLOWED_CHANNELS=@mychannel,-1001234567890

# Хранилище
# RICH_POSTS_DATA_DIR=/opt/rich-posts/backend/data
# RICH_POSTS_UPLOAD_RETENTION_SEC=14400
# RICH_POSTS_UPLOAD_USER_QUOTA_BYTES=419430400
# RICH_POSTS_HISTORY_MAX_ENTRIES=50

# Frontend (опционально при сборке)
# VITE_API_BASE=
# VITE_BASE=/

# CLI demo (scripts/send_rich_demo.py)
# DEMO_CHAT_ID=123456789
